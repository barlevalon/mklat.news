                    <enclosure url="https://img.haarets.co.il/bs/0000019c-b262-d7e7-a19c-bb7fc1850001/15/6d/5c383ee343a2811194e45de0af7e/085261-3.jpg?width=108&amp;height=81" type="image/jpeg" length="1020883"/>
                    
                        
